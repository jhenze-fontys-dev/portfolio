# ------------------------------------------------------------------------------
# BOOTSTRAP ENVIRONMENT CONFIGURATION
#
# Purpose   : Minimal configuration required to introspect data sources
#             before any generated .env exists.
# Used by   : dev/generators/generate.metadataStructure.js
#
# This file is hand-maintained.
# ------------------------------------------------------------------------------

# Runtime basics (safe defaults)
NODE_ENV=development
PORT=3000

# Logging
LOG_SCHEME=swagger

# ------------------------------------------------------------------------------
# Data source discovery
# ------------------------------------------------------------------------------

# Enabled data source types
DATA_SOURCES=sql

# SQL dialects to introspect (AND, not OR)
DB_DIALECT_LIST=sqlite

# ------------------------------------------------------------------------------
# SQLite configuration
# ------------------------------------------------------------------------------

# Absolute or relative path to SQLite database file
SQLITE_DB_FILE=./backend/data/sql/databases/finance.db


# ------------------------------------------------------------------------------
# PostgreSQL configuration
# ------------------------------------------------------------------------------

#POSTGRES_DB_HOST=localhost
#POSTGRES_DB_PORT=5432
#POSTGRES_DB_USER=postgres
#POSTGRES_DB_PASSWORD=Wiskunde+1
#POSTGRES_DB_NAME=fullstack_test

# IMPORTANT on Windows: point directly to psql.exe (avoids PATH issues)
#POSTGRES_PSQL_BIN=C:\Program Files\PostgreSQL\18\bin\psql.exe

# ------------------------------------------------------------------------------
# Metadata output
# ------------------------------------------------------------------------------

# Where generated metadataStructure.json will be written
METADATA_PATH=./dev/config/metadataStructure.json

# ------------------------------------------------------------------------------
# End of bootstrap environment configuration
# ------------------------------------------------------------------------------
